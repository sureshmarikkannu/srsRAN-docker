# Set proper timezone to sync times between docker host and containers
#TZ=Europe/Berlin

##########USER MOD START#############
MCC=001
MNC=01

DOCKER_HOST_IP=10.206.1.30

# UPF
UPF_IP=10.206.1.30

# IMS server IP
IMS_IP=10.206.1.30
##########USER MOD END#############

# Docker network
TEST_NETWORK=172.22.0.0/24

# IMS DNS
DNS_IP=172.22.0.3

# RTPENGINE
RTPENGINE_IP=$IMS_IP

# MYSQL
MYSQL_IP=172.22.0.5

# PYHSS
PYHSS_IP=172.22.0.6
PYHSS_BIND_PORT=3875

# ICSCF
ICSCF_IP=172.22.0.7
ICSCF_BIND_PORT=3869

# SCSCF
SCSCF_IP=172.22.0.8
SCSCF_BIND_PORT=3870

# PCSCF
PCSCF_IP=$IMS_IP
PCSCF_BIND_PORT=3871

#N5 PROXY
N5_PROXY_IP=$IMS_IP
N5_PROXY_PORT=7782

# SMSC
